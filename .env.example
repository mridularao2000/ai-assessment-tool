# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./assessment.db

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
LLM_MODEL=claude-sonnet-4-6

# ─── Resend ───────────────────────────────────────────────────────────────────
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=assessments@yourdomain.com
RESEND_FROM_NAME=AI Assessment System
USER_EMAIL=your_email@example.com

# ─── Application ──────────────────────────────────────────────────────────────
# Set to your deployed URL in production, e.g. https://ai-assessment.onrender.com
APP_BASE_URL=http://localhost:8000
UPLOADS_DIR=uploads
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SUBMISSION_TOKEN_SECRET=change-me-to-a-random-64-char-hex-secret

# ─── Assessment Scheduling ────────────────────────────────────────────────────
# Assessments are scheduled between these many days after target_completion_date.
# Enforced in AssessmentService._calculate_scheduled_at() (primary)
# and SchedulerService.schedule_assessment_jobs() (secondary guard).
ASSESSMENT_WINDOW_MIN_DAYS=1
ASSESSMENT_WINDOW_MAX_DAYS=3
REMINDER_HOURS_BEFORE=24

# ─── Mastery ──────────────────────────────────────────────────────────────────
MASTERY_THRESHOLD=85.0

# ─── LLM ──────────────────────────────────────────────────────────────────────
LLM_MAX_RETRIES=3
